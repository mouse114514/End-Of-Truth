; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="End Of Truth"
run/main_scene="res://main_menu.tscn"
config/features=PackedStringArray("4.3", "Mobile")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="res://icon.png"

[autoload]

BattleManager="*res://BattleManager.gd"
GameSettings="*res://GameSettings.gd"
MobileInput="*res://mobile_input_manager.gd"
PuzzleManager="*res://PuzzleManager.gd"
SoundManager="*res://SoundManager.gd"
StoryManager="*res://StoryManager.gd"

[display]

window/stretch/mode="viewport"

